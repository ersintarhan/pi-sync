{
  "name": "@ersintarhan/pi-sync",
  "version": "0.1.3",
  "description": "Encrypted + compressed per-session sync for pi coding agent (S3/R2 compatible).",
  "type": "module",
  "license": "MIT",
  "private": false,
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "sync",
    "s3",
    "encrypted",
    "session"
  ],
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "demo": "node --import tsx src/sync.ts"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.79.8",
    "@types/node": "^26.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ersintarhan/pi-sync.git"
  }
}
